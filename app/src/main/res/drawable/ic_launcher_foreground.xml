<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
        Cburnett white knight from the Lichess piece set (Colin M.L. Burnett, GPL/BSD/CC-BY-SA).
        Original viewBox="0 0 45 45". Scaled to 60×60 and centred on the 108dp adaptive-icon
        canvas: group translate=(24,24) scale=(60/45)=1.333.
    -->
    <group
        android:translateX="24"
        android:translateY="24"
        android:scaleX="1.333"
        android:scaleY="1.333">

        <!-- Knight body — white fill, dark stroke -->
        <path
            android:fillColor="#FFFFFF"
            android:fillType="evenOdd"
            android:strokeColor="#1A3A1A"
            android:strokeWidth="1.5"
            android:strokeLineCap="round"
            android:strokeLineJoin="round"
            android:pathData="M22 10c10.5 1 16.5 8 16 29H15c0-9 10-6.5 8-21" />

        <!-- Knight head / mane — white fill, dark stroke -->
        <path
            android:fillColor="#FFFFFF"
            android:fillType="evenOdd"
            android:strokeColor="#1A3A1A"
            android:strokeWidth="1.5"
            android:strokeLineCap="round"
            android:strokeLineJoin="round"
            android:pathData="M24 18c.38 2.91-5.55 7.37-8 9-3 2-2.82 4.34-5 4-1.042-.94 1.41-3.04 0-3-1 0 .19 1.23-1 2-1 0-4.003 1-4-4 0-2 6-12 6-12s1.89-1.9 2-3.5c-.73-.994-.5-2-.5-3 1-1 3 2.5 3 2.5h2s.78-1.992 2.5-3c1 0 1 3 1 3" />

        <!-- Eye dot (small circle at ~9,25) — drawn as two arcs -->
        <path
            android:fillColor="#1A1A1A"
            android:pathData="M9.5 25.5a.5.5 0 1 1-1 0 .5.5 0 1 1 1 0" />

    </group>
</vector>
